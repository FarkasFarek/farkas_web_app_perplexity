# ============================================================
# SUPABASE
# ============================================================

# A projekt publikus API URL-je
# Megtalalható: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Publikus (anon) kulcs – kliens- és szerverolaali hívásokhoz
# RLS-sel védett, nyugodtan publikus lehet
# Megtalalható: Supabase Dashboard → Project Settings → API → anon (public)
SUPABASE_KEY=your-supabase-anon-key

# Szerver oldali service_role kulcs – CSAK szerveroladali kódban!
# SOHA ne kerüljön kliensoldalra vagy public repóba
# Megtalalható: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================================
# NUXT / APP
# ============================================================

# Titkos kulcs a Nuxt session és CSRF védelemhez (min. 32 karakter)
# Generálás: openssl rand -base64 32
NUXT_SECRET_KEY=your-nuxt-secret-key-min-32-chars

# Az alkalmazás publikus alap URL-je
# Development: http://localhost:3000
# Production:  https://yourdomain.vercel.app
NUXT_PUBLIC_SITE_URL=https://yourdomain.vercel.app

# ============================================================
# VERCEL (automatikusan injektálva, nem kell manuálisan beállítani)
# ============================================================

# Az aktuális deployment környezet (production | preview | development)
# NUXT_ENV_VERCEL_ENV=production

# Az aktuális deployment URL-je (automatikus)
# VERCEL_URL=your-deployment.vercel.app

# ============================================================
# NEWS FETCHER (TAVILY + CURRENTS)
# ============================================================

# Tavily Search API kulcs hírek kereséséhez
# URL: https://app.tavily.com
# Ingyenes csomag: 1000 credit / hónap
TAVILY_API_KEY=tvly-...

# Currents API kulcs hírek lekéréséhez
# URL: https://currentsapi.services
# Ingyenes csomag: 600 kérés / nap
CURRENTS_API_KEY=...

# Edge Function auth secret a /news-fetch végpont védelméhez
# Generálás: openssl rand -hex 32
NEWS_FETCH_SECRET=<openssl rand -hex 32>
